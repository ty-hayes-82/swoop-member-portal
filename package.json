{
  "name": "swoop-golf-platform",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/prebuild-safe-clean.mjs && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p jsconfig.json",
    "lint-theme": "node scripts/lint-theme.mjs",
    "lint-clubid": "node scripts/lint-clubid.mjs",
    "lint-dollars": "node scripts/lint-no-hardcoded-dollars.mjs",
    "lint": "npm run lint-theme && npm run lint-clubid && npm run lint-dollars",
    "db:migrate": "node scripts/migrate.mjs",
    "test:e2e": "npx playwright test",
    "test:insights": "npx playwright test --config=playwright.insights.config.js",
    "insights:report": "node scripts/generate-insights-report.mjs",
    "insights:critique": "node scripts/critique-insights.mjs",
    "insights:full": "npm run test:insights && npm run insights:report && npm run insights:critique",
    "vision:capture": "npx playwright test --config=playwright.insights.config.js",
    "vision:critique": "node scripts/gemini-critique.mjs",
    "vision:full": "npm run vision:capture && npm run vision:critique",
    "app:critique": "node scripts/app-vision-critique.mjs",
    "scoring:run": "node scripts/scoring-loop.mjs",
    "scoring:quick": "QUICK_MODE=1 node scripts/scoring-loop.mjs",
    "test:pinetree:setup": "node scripts/pinetree-setup.mjs",
    "test:pinetree": "APP_URL=https://swoop-member-portal-dev.vercel.app npx playwright test tests/e2e/pinetree-concierge.spec.js --project=\"Desktop Chrome\" --reporter=html",
    "test:pinetree:local": "APP_URL=http://localhost:3000 npx playwright test tests/e2e/pinetree-concierge.spec.js --project=\"Desktop Chrome\" --reporter=html",
    "concierge:score": "node scripts/sms-concierge-score.mjs",
    "concierge:score:local": "APP_URL=http://localhost:3000 node scripts/sms-concierge-score.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.87.0",
    "@google/genai": "^1.50.1",
    "@sentry/react": "^10.48.0",
    "@vercel/postgres": "^0.10.0",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.13.1",
    "recharts": "^2.12.0",
    "tailwind-merge": "^3.5.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@google/generative-ai": "^0.24.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@vitejs/plugin-react": "^4.2.0",
    "docx": "^9.6.1",
    "jsdom": "^28.1.0",
    "pg": "^8.20.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "vite": "^5.0.0",
    "vite-plugin-svgr": "^4.5.0",
    "vitest": "^2.1.8"
  }
}
