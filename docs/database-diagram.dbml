// ============================================
// TABLE GROUPS
// ============================================

TableGroup Core {
  club
  members
  households
  membership_types
  users
  sessions
  user_sessions
}

TableGroup Golf_Operations {
  bookings
  booking_players
  booking_confirmations
  rounds
  courses
  pace_of_play
  pace_hole_segments
  slot_reassignments
  waitlist_entries
  waitlist_config
  member_waitlist
  cancellation_risk
  demand_heatmap
}

TableGroup Dining_and_POS {
  dining_outlets
  pos_checks
  pos_line_items
  pos_payments
  close_outs
  transactions
}

TableGroup Events {
  canonical_events
  event_definitions
  event_registrations
  event_roi_metrics
}

TableGroup Communications {
  email_campaigns
  email_events
  notifications
  notification_preferences
}

TableGroup Feedback_and_Service {
  feedback
  service_requests
  service_recovery_alerts
  complaints
}

TableGroup Member_Analytics {
  member_engagement_daily
  member_engagement_weekly
  health_scores
  member_sentiment_ratings
  churn_predictions
  member_invoices
  visit_sessions
  member_location_current
}

TableGroup AI_Agents {
  agent_definitions
  agent_actions
  agent_activity
  agent_configs
}

TableGroup Actions_and_Interventions {
  actions
  interventions
  member_interventions
  operational_interventions
  playbook_runs
  playbook_steps
}

TableGroup Data_Management {
  data_syncs
  data_source_status
  csv_imports
  connected_systems
  feature_dependency
  feature_state_log
  onboarding_progress
}

TableGroup Analytics_and_Insights {
  archetype_spend_gaps
  board_report_snapshots
  correlations
  correlation_insights
  experience_correlations
  industry_benchmarks
  weather_daily
}

TableGroup Staff {
  staff
  staff_shifts
  staff_location_current
}

TableGroup Activity {
  activity_log
}

