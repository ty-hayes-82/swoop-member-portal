  recommended_fill_member_name varchar(100)
  status varchar(20) [default: 'pending']
  staff_decision text
  revenue_recovered numeric
  health_before integer
  health_after integer
  decided_at timestamptz
  audit_trail jsonb [default: '[]']
}

Table staff {
  staff_id text [pk]
  club_id text [not null]
  first_name text [not null]
  last_name text [not null]
  department text [not null]
  role text [not null]
  hire_date text [not null]
  hourly_rate real [not null]
  is_full_time integer [not null, default: 1]
}

Table staff_location_current {
  staff_id varchar(20) [pk]
  name varchar(100)
  zone varchar(50)
  status varchar(20)
  eta_minutes integer
  department varchar(50)
}

Table staff_shifts {
  shift_id text [pk]
  staff_id text [not null]
  shift_date text [not null]
  outlet_id text
  start_time text [not null]
  end_time text [not null]
  hours_worked real [not null]
  is_understaffed_day integer [not null, default: 0]
  notes text
}

Table transactions {
  transaction_id text [pk, default: `gen_random_uuid()`]
  club_id text [not null]
  member_id text
  outlet_id text
  outlet_name text
  transaction_date timestamptz [not null]
  total_amount numeric
  item_count integer
  category text
  is_post_round boolean [default: false]
  data_source text [default: 'pos']
  created_at timestamptz [default: `now()`]
}

Table user_sessions {
  id integer [pk, default: `nextval('user_sessions_id_seq'::regclass)`]
  user_id varchar(50) [not null, default: 'gm_default']
  last_login_at timestamptz [not null, default: `now()`]
  created_at timestamptz [not null, default: `now()`]
}

Table users {
  user_id text [pk, default: `gen_random_uuid()`]
  club_id text [not null]
  email text [not null, unique]
  name text [not null]
  role text [not null, default: 'viewer']
  title text
  active boolean [default: true]
  last_login timestamptz
  created_at timestamptz [default: `now()`]
  password_hash text
  password_salt text
}

Table visit_sessions {
  session_id text [pk]
  member_id text [not null]
  session_date text [not null]
  anchor_type text [not null]
  arrival_time text
  departure_time text
  duration_minutes integer
  touchpoints integer [not null, default: 1]
  total_spend real [not null, default: 0]
  activities text [not null, default: '[]']
}

Table waitlist_config {
  club_id varchar(20) [pk, default: 'oakmont']
  hold_time_minutes integer [default: 30]
  auto_offer_threshold numeric [default: 0.80]
  max_offers integer [default: 3]
  notification_limit integer [default: 2]
}

Table waitlist_entries {
  entry_id text [pk]
  club_id text [not null]
  course_id text [not null]
  requested_date text [not null]
  requested_tee_time text [not null]
  waitlist_count integer [not null, default: 1]
  has_event_overlap integer [not null, default: 0]
  peak_slot text
}

Table weather_daily {
  weather_id text [pk]
  date text [not null, unique]
  condition text [not null]
  temp_high integer [not null]
  temp_low integer [not null]
  wind_mph integer [not null, default: 0]
  precipitation_in real [not null, default: 0]
  golf_demand_modifier real [not null, default: 0]
  fb_demand_modifier real [not null, default: 0]
}

