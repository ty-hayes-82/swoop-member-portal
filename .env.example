# Swoop Golf Member Portal — Environment Variables
#
# See docs/operations/RUNBOOK.md § 3 "Environment Variables" for full setup.
# Copy this file to .env.local and fill in real values for local development.
# For production, set these in the Vercel project settings (Environment Variables).
#
# NEVER commit a populated .env.local — only this template ships in git.
# Generated from `process.env.*` references across api/, src/, and scripts/.

# ─── Vercel Postgres ──────────────────────────────────────────────────────
# REQUIRED. The pooled and non-pooled connection strings provided by Vercel.
# Found in: Vercel Dashboard → Project → Storage → Postgres → .env.local tab
POSTGRES_URL=postgresql://user:password@host/dbname?sslmode=require
POSTGRES_URL_NON_POOLING=postgresql://user:password@host/dbname?sslmode=require

# ─── App configuration ────────────────────────────────────────────────────
# Public URL the frontend uses to call its own API.
# Local default: http://localhost:5174 — set explicitly only for previews.
APP_URL=

# Vercel sets NODE_ENV automatically. Override only for special test envs.
NODE_ENV=

# Set to "true" to enable /api/debug-* and /api/check-* endpoints.
# DO NOT enable in production.
ALLOW_DEBUG=

# ─── AI / Drafting providers ──────────────────────────────────────────────
# Optional. Selects the LLM backend used by api/agents/draft.js.
# Allowed values: "anthropic" | "google" | "gemini"
AI_DRAFT_PROVIDER=

# Required if AI_DRAFT_PROVIDER=anthropic. Format: sk-ant-...
ANTHROPIC_API_KEY=

# Required if AI_DRAFT_PROVIDER=google or gemini.
GOOGLE_AI_API_KEY=

# Used by scripts/gemini-critique.mjs (visual QA pipeline).
GEMINI_API_KEY=

# ─── Google OAuth (Calendar + Gmail integration) ──────────────────────────
# Optional. Required only if clubs use Gmail draft / Calendar event features.
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google's "Weather API" (used by api/cron/weather-daily.js).
GOOGLE_WEATHER_API_KEY=

# ─── Visual Crossing weather (alternative provider) ───────────────────────
# Drop-in alternative to GOOGLE_WEATHER_API_KEY.
VISUAL_CROSSING_API_KEY=

# ─── Twilio (SMS messaging) ───────────────────────────────────────────────
# Required only if clubs use SMS recovery/apology flows.
# Get from: https://console.twilio.com/
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_PHONE_NUMBER=

# ─── SendGrid (email delivery) ────────────────────────────────────────────
# Used by transactional email flows. Format: SG....
SENDGRID_API_KEY=

# ─── Vercel cron jobs ─────────────────────────────────────────────────────
# REQUIRED for /api/cron/* endpoints. Long random string. Vercel passes it as
# Authorization: Bearer <value> when the cron tick fires. Generate with:
#   openssl rand -hex 32
CRON_SECRET=

# ─── Operational metrics scrape ───────────────────────────────────────────
# Shared secret that protects /api/metrics. External scrapers (Better Stack,
# Pingdom, etc.) pass it as `x-metrics-token: <value>`. If unset, the endpoint
# returns 401 for all requests. Generate with: openssl rand -hex 32
METRICS_TOKEN=

# ─── Frontend feature flags (Vite) ────────────────────────────────────────
# Set to 'true' to enable live API calls (Phase 2). 'false' uses static demo data.
VITE_API_ENABLED=true

# ─── Error telemetry (Sentry) ─────────────────────────────────────────────
# Optional. When set, src/main.jsx initializes @sentry/react and the
# logError() helper in src/utils/logError.js forwards service errors to
# Sentry. When unset, logError falls through to console.error only — dev
# builds behave identically to the pre-Sentry codebase.
VITE_SENTRY_DSN=

# Optional. Tags the Sentry release with the git SHA (Vercel exposes this
# as VERCEL_GIT_COMMIT_SHA; wire it through in the Vercel build settings).
VITE_GIT_SHA=
