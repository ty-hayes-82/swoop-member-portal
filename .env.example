# Swoop Golf Five Lenses Platform — Environment Variables
# Copy to .env.local and fill in values

# =============================================================================
# Database (Vercel Postgres / Neon) — Required
# =============================================================================
POSTGRES_URL=postgresql://user:password@host/dbname?sslmode=require
POSTGRES_URL_NON_POOLING=postgresql://user:password@host/dbname?sslmode=require

# =============================================================================
# SendGrid (email notifications) — Required for email features
# =============================================================================
SENDGRID_API_KEY=

# =============================================================================
# Twilio (SMS notifications) — Optional, needed for SMS playbook actions
# =============================================================================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=

# =============================================================================
# Anthropic (AI agent system) — Optional, needed for agent draft/explain/sweep
# =============================================================================
ANTHROPIC_API_KEY=

# =============================================================================
# Feature Flags (client-side, prefixed with VITE_)
# =============================================================================
# Set to 'true' to enable live API calls (Phase 2). 'false' uses static demo data.
VITE_API_ENABLED=true
