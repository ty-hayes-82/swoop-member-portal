# Production Environment Variables
# Copy to Vercel dashboard → Settings → Environment Variables

# Required
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=
SENDGRID_API_KEY=

# Optional
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
ANTHROPIC_API_KEY=

# Feature Flags
VITE_API_ENABLED=true

# Debug (set to 'true' only for troubleshooting — NEVER in production)
ALLOW_DEBUG=false
