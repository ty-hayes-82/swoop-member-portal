{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "crons": [
    { "path": "/api/cron/weather-daily", "schedule": "0 3 * * *" },
    { "path": "/api/cron/purge-cross-club-audit", "schedule": "0 4 * * *" },
    { "path": "/api/cron/playbook-timers", "schedule": "0 8 * * *" },
    { "path": "/api/cron/health-monitor", "schedule": "0 10 * * *" },
    { "path": "/api/cron/daily-gameplan", "schedule": "0 5 * * *" },
    { "path": "/api/cron/staffing-monitor", "schedule": "0 6 * * *" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "https://swoop-member-portal.vercel.app" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, PUT, DELETE, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Authorization, Content-Type" },
        { "key": "Access-Control-Max-Age", "value": "86400" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/landing.html", "destination": "/landing.html" },
    { "source": "/((?!assets/).*)", "destination": "/index.html" }
  ]
}
