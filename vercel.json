{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/landing.html", "destination": "/landing.html" },
    { "source": "/((?!assets/).*)", "destination": "/index.html" }
  ]
}
