{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "crons": [
    { "path": "/api/cron/weather-daily", "schedule": "0 3 * * *" }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/landing.html", "destination": "/landing.html" },
    { "source": "/((?!assets/).*)", "destination": "/index.html" }
  ]
}
